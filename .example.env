# Interface (optional override used in commands; keep eno1 if set there)
P0F_INTERFACE=eth0

HOST_UID=1000
HOST_GID=1000

# Per-service BPF filters (one host each)
WINDOWS_FILTER="host x.x.x.x and tcp"
LINUX_FILTER="host x.x.x.x and not port 22"
OTHER_FILTER="host x.x.x.x and (tcp or icmp)"

# Logrotate (if your sidecar expects these, add them; otherwise omit)
LOGROTATE_INTERVAL=86400
LOGROTATE_MAX_DAYS=7